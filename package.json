{
  "name": "@luka-cat-mimi/n8n-nodes-moka-people",
  "version": "0.1.1",
  "description": "Moka People N8N 集成插件",
  "keywords": [
    "n8n",
    "n8n-node",
    "n8n-community-node-package",
    "moka",
    "moka-people"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "homepage": "https://github.com/luka-n8n-nodes/n8n-nodes-moka-people#readme",
  "author": {
    "name": "luka-cat",
    "email": "luka.cat.mimi@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luka-n8n-nodes/n8n-nodes-moka-people.git"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "index.js",
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "format": "prettier credentials nodes --write",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/MokaPeopleApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/MokaPeople/MokaPeople.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@n8n/node-cli": "*",
    "eslint": "9.39.4",
    "prettier": "3.8.3",
    "release-it": "20.0.1",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "form-data": "^4.0.5",
    "glob": "^13.0.6"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
